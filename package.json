{
	"name": "otel-bun",
	"workspaces": {
		"packages": [
			"apps/*",
			"packages/*"
		],
		"catalog": {
			"@convex-dev/better-auth": "^0.10.13",
			"@edge-runtime/vm": "^5.0.0",
			"@types/node": "^25.5.0",
			"add": "^2.0.6",
			"better-auth": "1.5.5",
			"bun": "^1.3.10",
			"convex": "^1.33.1",
			"convex-test": "^0.0.41",
			"dotenv": "^17.3.1",
			"tsdown": "^0.20.3",
			"typescript": "^5.9.3",
			"vitest": "^4.1.0",
			"zod": "^4.3.6"
		}
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.7",
		"alchemy": "^0.83.3",
		"dotenv": "^17.2.3",
		"turbo": "^2.8.17"
	},
	"packageManager": "bun@1.3.1",
	"private": true,
	"scripts": {
		"lint": "biome check --write .",
		"check:unsafe": "biome check --write --unsafe .",
		"a:clean": "rm -rf .alchemy && turbo a:clean",
		"a:dev": "alchemy dev --env-file .env.dev",
		"a:dev:destroy": "alchemy destroy --env-file .env.dev",
		"a:prod:deploy": "alchemy deploy --env-file .env.prod",
		"a:prod:destroy": "alchemy destroy --env-file .env.prod",
		"a:staging:deploy": "alchemy deploy --env-file .env.staging",
		"a:staging:destroy": "alchemy destroy --env-file .env.staging",
		"vite:dev": "turbo dev",
		"vite:clean": "turbo -F web vite:clean",
		"build": "turbo -F web build",
		"typecheck": "turbo typecheck",
		"dev:native": "turbo -F native dev",
		"dev:web": "turbo -F web dev",
		"dev:server": "turbo -F server dev",
		"otel-dev:server": "turbo -F server otel-dev",
		"db:push": "turbo -F server db:push",
		"db:studio": "turbo -F server db:studio",
		"db:generate": "turbo -F server db:generate",
		"db:migrate": "turbo -F server db:migrate",
		"do:generate": "turbo -F server do:generate",
		"auth:generate": "turbo -F server auth:generate",
		"ruler:apply": "bunx @intellectronica/ruler@latest apply --local-only"
	}
}
