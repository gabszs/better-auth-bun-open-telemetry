{
	"name": "server",
	"main": "src/index.ts",
	"type": "module",
	"private": true,
	"dependencies": {
		"@better-auth/redis-storage": "^1.5.5",
		"@hono-rate-limiter/redis": "^0.1.4",
		"@hono/otel": "^1.1.0",
		"@hono/zod-openapi": "^1.2.0",
		"@otel-bun/bun-instrumentation-pg": "workspace:*",
		"@otel-bun/bun-instrumentation-redis": "workspace:*",
		"@opentelemetry/api": "^1.9.0",
		"@opentelemetry/api-logs": "^0.213.0",
		"@opentelemetry/auto-instrumentations-node": "^0.71.0",
		"@opentelemetry/exporter-metrics-otlp-http": "^0.213.0",
		"@opentelemetry/exporter-trace-otlp-http": "^0.213.0",
		"@opentelemetry/host-metrics": "^0.38.3",
		"@opentelemetry/resources": "^2.6.0",
		"@opentelemetry/sdk-metrics": "^2.6.0",
		"@opentelemetry/sdk-node": "^0.213.0",
		"@opentelemetry/semantic-conventions": "^1.40.0",
		"@orpc/server": "^1.13.2",
		"@scalar/hono-api-reference": "^0.9.30",
		"@scalar/openapi-to-markdown": "^0.4.7",
		"better-auth": "1.4.10",
		"better-auth-cloudflare": "^0.2.9",
		"drizzle-orm": "^0.45.1",
		"drizzle-zod": "^0.8.3",
		"hono": "^4.12.8",
		"hono-rate-limiter": "^0.5.3",
		"pino": "^10.3.1",
		"pino-pretty": "^13.1.3",
		"postgres": "^3.4.8",
		"resend": "^6.6.0",
		"ua-parser-js": "^2.0.7",
		"zod": "catalog:"
	},
	"scripts": {
		"build": "bun run typecheck",
		"typecheck": "tsc -b",
		"compile": "bun build --compile --minify --sourcemap --bytecode ./src/index.ts --outfile server",
		"dev": "bun --hot src/index.ts",
		"otel-dev": "bun --hot --preload src/otel.ts src/index.ts",
		"db:generate": "drizzle-kit generate --config=./drizzle.config.ts --name",
		"db:migrate": "drizzle-kit migrate --config=./drizzle.config.ts",
		"db:studio": "drizzle-kit studio --config=./drizzle.config.ts",
		"db:studio:prod": "drizzle-kit studio --config=./drizzle.config.ts",
		"auth:generate": "bunx --bun @better-auth/cli@1.4.2 generate --config src/lib/auth.ts --output src/db/models/authModels.ts -y"
	},
	"devDependencies": {
		"@types/node": "catalog:",
		"dotenv": "catalog:",
		"drizzle-kit": "^0.31.8",
		"tsdown": "catalog:",
		"tsx": "^4.21.0",
		"typescript": "catalog:",
		"vitest": "catalog:"
	}
}
